// SignalForge — complete data model

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ─── Workspace & Users ────────────────────────────────────────────────────────

model Workspace {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  plan      String   @default("free")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users              WorkspaceMember[]
  accounts           ConnectedAccount[]
  sources            Source[]
  signals            Signal[]
  leads              Lead[]
  campaigns          Campaign[]
  automationPolicies AutomationPolicy[]
  activityLogs       ActivityLog[]
  proxyProfiles      ProxyProfile[]
  warmupPlans        WarmupPlan[]
}

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  avatarUrl     String?
  timezone      String   @default("UTC")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workspaces      WorkspaceMember[]
  ownedLeads      Lead[]             @relation("LeadOwner")
  approvedReplies ThreadEngagement[]
  sessions        Session[]
  authAccounts    Account[]
}

model WorkspaceMember {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String
  role        String   @default("OPERATOR")
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
}

// ─── better-auth tables ───────────────────────────────────────────────────────

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([providerId, accountId])
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@unique([identifier, value])
}

// ─── Platform Accounts ────────────────────────────────────────────────────────

model ConnectedAccount {
  id                String   @id @default(cuid())
  workspaceId       String
  platform          String
  displayName       String
  username          String
  externalAccountId String?
  authType          String   @default("cookie")
  authStatus        String   @default("PENDING")
  warmupStatus      String   @default("IDLE")
  healthStatus      String   @default("UNKNOWN")
  reputationScore   Int      @default(0)
  riskScore         Int      @default(0)
  dailyActionLimit  Int      @default(20)
  assignedProxyId      String?
  encryptedCredentials String?
  accessToken          String?
  refreshToken         String?
  tokenExpiresAt       DateTime?
  metadata             String?
  lastSeenAt           DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  workspace       Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  proxy           ProxyProfile?    @relation(fields: [assignedProxyId], references: [id])
  warmupPlans     WarmupPlan[]
  engagements     ThreadEngagement[]
  dmConversations DmConversation[]
  warmupActions   WarmupAction[]
}

model ProxyProfile {
  id                String   @id @default(cuid())
  workspaceId       String
  label             String
  type              String
  host              String
  port              Int
  username          String?
  passwordEncrypted String?
  country           String?
  city              String?
  status            String   @default("active")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  workspace Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  accounts  ConnectedAccount[]
}

// ─── Sources ──────────────────────────────────────────────────────────────────

model Source {
  id               String   @id @default(cuid())
  workspaceId      String
  platform         String
  sourceType       String
  name             String
  externalSourceId String?
  url              String?
  joinStatus       String   @default("pending")
  priority         Int      @default(5)
  tags             String   @default("[]")
  monitoringMode   String   @default("passive")
  ingestionStatus  String   @default("idle")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  workspace    Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  rules        SourceRule[]
  contentItems ContentItem[]
}

model SourceRule {
  id       String  @id @default(cuid())
  sourceId String
  ruleType String
  operator String  @default("contains")
  value    String
  weight   Float   @default(1.0)
  isActive Boolean @default(true)

  source Source @relation(fields: [sourceId], references: [id], onDelete: Cascade)
}

// ─── Content & Signals ────────────────────────────────────────────────────────

model ContentItem {
  id                String    @id @default(cuid())
  workspaceId       String
  sourceId          String
  platform          String
  externalContentId String?
  contentType       String
  authorName        String?
  authorHandle      String?
  authorMeta        String?
  title             String?
  bodyText          String
  permalink         String?
  postedAt          DateTime?
  ingestedAt        DateTime  @default(now())
  language          String?
  metadata          String?

  source  Source   @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  signals Signal[]
}

model Signal {
  id                String   @id @default(cuid())
  workspaceId       String
  contentItemId     String
  signalType        String   @default("intent")
  intentScore       Int      @default(0)
  urgencyScore      Int      @default(0)
  fitScore          Int      @default(0)
  spamProbability   Float    @default(0)
  sentiment         String?
  extractedKeywords String   @default("[]")
  extractedNeed     String?
  aiSummary         String?
  recommendedAction String?
  status            String   @default("NEW")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  workspace   Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contentItem ContentItem        @relation(fields: [contentItemId], references: [id])
  engagements ThreadEngagement[]
  leads       Lead[]
}

// ─── Leads ────────────────────────────────────────────────────────────────────

model Lead {
  id                String    @id @default(cuid())
  workspaceId       String
  platform          String
  sourceSignalId    String?
  displayName       String
  handle            String?
  contactChannel    String?
  leadStatus        String    @default("new")
  pipelineStage     String    @default("NEW")
  ownerUserId       String?
  temperature       String    @default("cold")
  estimatedValue    Float?
  tags              String    @default("[]")
  notes             String?
  lastInteractionAt DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  workspace       Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  sourceSignal    Signal?          @relation(fields: [sourceSignalId], references: [id])
  owner           User?            @relation("LeadOwner", fields: [ownerUserId], references: [id])
  dmConversations DmConversation[]
}

// ─── Engagement ───────────────────────────────────────────────────────────────

model ThreadEngagement {
  id           String    @id @default(cuid())
  workspaceId  String
  signalId     String
  accountId    String
  platform     String
  replyText    String
  replyVersion Int       @default(1)
  tone         String?
  actionStatus String    @default("DRAFT")
  sentAt       DateTime?
  operatorId   String?
  aiGenerated  Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  signal   Signal           @relation(fields: [signalId], references: [id])
  account  ConnectedAccount @relation(fields: [accountId], references: [id])
  operator User?            @relation(fields: [operatorId], references: [id])
}

// ─── DM Conversations ─────────────────────────────────────────────────────────

model DmConversation {
  id                 String    @id @default(cuid())
  workspaceId        String
  leadId             String
  accountId          String
  platform           String
  conversationStatus String    @default("ACTIVE")
  lastMessageAt      DateTime?
  unreadCount        Int       @default(0)
  summary            String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  lead     Lead             @relation(fields: [leadId], references: [id])
  account  ConnectedAccount @relation(fields: [accountId], references: [id])
  messages DmMessage[]
}

model DmMessage {
  id                String   @id @default(cuid())
  conversationId    String
  direction         String
  senderType        String
  bodyText          String
  messageType       String   @default("text")
  deliveryStatus    String   @default("sent")
  externalMessageId String?
  sentAt            DateTime @default(now())
  createdAt         DateTime @default(now())

  conversation DmConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

// ─── Warmup ───────────────────────────────────────────────────────────────────

model WarmupPlan {
  id           String   @id @default(cuid())
  workspaceId  String
  accountId    String
  status       String   @default("active")
  dailyTargets String?
  schedule     String?
  tonePreset   String?
  sourceScope  String?
  delayProfile String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workspace Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  account   ConnectedAccount @relation(fields: [accountId], references: [id])
  actions   WarmupAction[]
}

model WarmupAction {
  id           String    @id @default(cuid())
  warmupPlanId String
  accountId    String
  platform     String
  actionType   String
  targetRef    String?
  actionStatus String    @default("pending")
  scheduledAt  DateTime?
  executedAt   DateTime?
  resultMeta   String?

  warmupPlan WarmupPlan       @relation(fields: [warmupPlanId], references: [id], onDelete: Cascade)
  account    ConnectedAccount @relation(fields: [accountId], references: [id])
}

// ─── Automation ───────────────────────────────────────────────────────────────

model AutomationPolicy {
  id                          String   @id @default(cuid())
  workspaceId                 String   @unique
  mode                        String   @default("manual")
  publicReplyApprovalRequired Boolean  @default(true)
  dmApprovalRequired          Boolean  @default(true)
  riskTolerance               String   @default("low")
  quietHours                  String?
  rateLimits                  String?
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

// ─── Campaigns ────────────────────────────────────────────────────────────────

model Campaign {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  niche       String?
  offerType   String?
  status      String   @default("active")
  toneProfile String?
  sourceSet   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

// ─── Activity Logs ────────────────────────────────────────────────────────────

model ActivityLog {
  id          String   @id @default(cuid())
  workspaceId String
  actorType   String
  entityType  String
  actorId     String?
  entityId    String?
  action      String
  details     String?
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}
